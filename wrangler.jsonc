{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rac-cloud",
  "main": ".open-next/worker.js",
  "no_bundle": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "fd8844cf-cba3-4f18-9986-e52d20b548d5-db",
      "database_id": "ccae0cce-0ed8-4fc0-88f4-51c7bb99f0d7"
    }
  ]
}
